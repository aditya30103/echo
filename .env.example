# Copy this file to .env and fill in values. Never commit .env.

# YouTube Data API v3
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Used by: enrich.py (fetches video metadata: title, category, duration)
# Quota: 10,000 units/day free. enrich.py uses ~1 unit per video.
YOUTUBE_API_KEY=

# OpenAI API
# Get from: platform.openai.com → API Keys
# Used by: reflect.py (GPT-4o chapter reflections and autobiography)
# Model: gpt-4o. Requires gpt-4o access on your account.
OPENAI_API_KEY=
