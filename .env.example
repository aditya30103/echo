# Copy this file to .env and fill in values. Never commit .env.

# YouTube Data API v3
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Used by: enrich.py (fetches video metadata: title, category, duration)
# Quota: 10,000 units/day free. enrich.py uses ~1 unit per video.
YOUTUBE_API_KEY=

# OpenAI API (direct)
# Get from: platform.openai.com → API Keys
# Used by: reflect.py (GPT-4o chapter reflections and autobiography)
# Model: gpt-4o. Requires gpt-4o access on your account.
OPENAI_API_KEY=

# OpenRouter API (alternative to OPENAI_API_KEY)
# Get from: openrouter.ai → Keys
# reflect.py prefers OPENAI_API_KEY if both are set; falls back to OpenRouter.
# Uses openai/gpt-4o. Budget: ~$0.15 for all 16 chapters + autobiography.
OPENROUTER_API_KEY=

# Anthropic API (direct — preferred for Echo Speaks)
# Get from: console.anthropic.com → API Keys
# Used by: api/llm.py (Echo Speaks ReAct loop, Ask Echo chat)
ANTHROPIC_API_KEY=

# Python sandbox gate — controls whether execute_python tool is active in Echo Speaks
# Set to "true" only in trusted local environments where you are the only user.
# The agent can run arbitrary Python in the server process with no sandboxing.
# Docker Compose sets this to "false" by default. Do not override on shared networks.
UNSAFE_PYTHON_SANDBOX=false

# Spotify API (optional — enrich_spotify.py fetches track metadata and genres)
# Create an app at developer.spotify.com/dashboard. Client Credentials flow only (no user auth).
# Note: audio features (valence, energy, danceability etc.) require an app registered before Nov 2024.
# Apps created after Nov 2024 will get NULL for those columns; all other metadata is still fetched.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Langfuse observability (optional — tracing for Echo Speaks agent)
# Get from: cloud.langfuse.com → Settings → API Keys
# If unset, tracing is silently skipped. No other behavior changes.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
