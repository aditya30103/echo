# Copy this file to .env and fill in values. Never commit .env.
# Most keys are optional — Echo's scripts run with whichever ones you set.
# See SETUP.md for which keys you need for which features.

# ── YouTube Data API v3 ────────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Used by: enrich.py (fetches video metadata: title, category, duration, tags)
# Quota: 10,000 units/day free. enrich.py uses ~1 unit per video.
YOUTUBE_API_KEY=

# ── OpenAI API (direct) ────────────────────────────────────────────────────
# Get from: platform.openai.com → API Keys
# Used by:
#   reflect.py — GPT-4o chapter reflections + autobiography
#   embed.py   — text-embedding-3-small for the LanceDB corpora
#   api/llm.py — Echo Speaks fallback when ANTHROPIC_API_KEY is absent
# Requires gpt-4o + text-embedding-3-small access on your account.
OPENAI_API_KEY=

# ── OpenRouter API (alternative path for OpenAI calls) ─────────────────────
# Get from: openrouter.ai → Keys
# reflect.py, embed.py, and api/llm.py all prefer OPENAI_API_KEY when set;
# they fall back to OpenRouter (model id prefixed with 'openai/') otherwise.
# Budget: ~$0.15 for a full 16-chapter + autobiography reflection pass.
OPENROUTER_API_KEY=

# ── Anthropic API (preferred LLM for Echo Speaks) ──────────────────────────
# Get from: console.anthropic.com → API Keys
# Used by: api/llm.py — Echo Speaks ReAct loop, Ask Echo chat.
# api/llm.py uses the Anthropic native path when this is set (better prompt caching).
ANTHROPIC_API_KEY=

# ── Python sandbox gate ────────────────────────────────────────────────────
# Controls the execute_python tool in Echo Speaks.
# Set to "true" only in trusted local environments where YOU are the only user.
# The agent can run arbitrary Python in the server process with no sandboxing.
# Docker Compose sets this to "false" by default. Never set "true" on a shared network.
UNSAFE_PYTHON_SANDBOX=false

# ── Spotify Web API (optional — enrich_spotify.py) ─────────────────────────
# Create an app at developer.spotify.com/dashboard. Client Credentials flow (no user auth).
# Note: audio features (valence, energy, danceability, etc.) require an app registered
# before Nov 2024. Apps created after that date get NULL for those columns; basic
# metadata (duration, explicit, name, artist) still works.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: filename inside `_data/` for your Spotify export zip.
# Default is "my_spotify_data.zip" - uncomment + edit only if your filename differs.
# SPOTIFY_ZIP=my_spotify_data.zip

# ── Last.fm API (optional - enrich_music_meta.py) ──────────────────────────
# Create an app at last.fm/api/account/create (instant, no review). Free.
# Used by: enrich_music_meta.py - sources artist + track community tags for
# the mood/genre dimension that powers cross-modal queries like
# "when was I in a melancholy phase, and what was I watching?"
# If unset, enrich-music-meta is skipped (echo run continues to the next step).
LASTFM_API_KEY=

# ── Langfuse observability (optional — Echo Speaks agent tracing) ──────────
# Get from: cloud.langfuse.com → Settings → API Keys
# If unset, tracing is silently skipped. No other behavior changes.
# NOTE: the host env var is named LANGFUSE_HOST (NOT LANGFUSE_BASE_URL).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── UI dev override (optional) ─────────────────────────────────────────────
# Used by: ui/vite.config.ts — proxies /api requests from the SvelteKit dev server.
# Default: http://127.0.0.1:8000 (matches `uvicorn api.main:app --port 8000`).
# Docker Compose sets this to http://api:8000 automatically.
# Uncomment + edit only if your API runs at a non-default host/port.
# VITE_API_URL=http://127.0.0.1:8000
